<?xml version="1.0" encoding="UTF-8"?>
<form addfieldprefix="Joomla\Component\MCP\Administrator\Field">
	<fieldset name="details">
		<field
			name="id"
			type="hidden"
			default="0"
		/>

		<field
			name="client_name"
			type="text"
			label="COM_MCP_FIELD_CLIENT_NAME_LABEL"
			required="true"
		/>

		<field
			name="client_token"
			type="text"
			label="COM_MCP_FIELD_CLIENT_TOKEN_LABEL"
			readonly="true"
			class="readonly font-monospace"
		/>

		<field
			name="claude_code_cli"
			type="mcpconfig"
			label="COM_MCP_FIELD_MCP_CONFIG_CLAUDE_CODE_TITLE"
			description="COM_MCP_FIELD_MCP_CONFIG_CLAUDE_CODE_DESC"
			subtype="claudecode"
		/>

		<field
			name="full_config"
			type="mcpconfig"
			label="COM_MCP_FIELD_MCP_CONFIG_FULL_TITLE"
			description="COM_MCP_FIELD_MCP_CONFIG_FULL_DESC"
			subtype="fullconfig"
		/>

		<field
			name="username"
			type="hidden"
		/>
	</fieldset>

	<fieldset name="details2">
		<field
			name="state"
			type="list"
			label="JSTATUS"
			class="form-select-color-state"
			default="1"
			validate="options"
			>
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="2">JARCHIVED</option>
			<option value="-2">JTRASHED</option>
		</field>

		<field
			name="ordering"
			type="list"
			label="JFIELD_ORDERING_LABEL"
			table="#__mcp"
			field="ordering"
		/>

		<field
			name="version_note"
			type="text"
			label="JGLOBAL_FIELD_VERSION_NOTE_LABEL"
			maxlength="255"
		/>

	</fieldset>

	<fieldset name="publish">
		<field
			name="created"
			type="calendar"
			label="COM_MCP_FIELD_CREATED_LABEL"
			translateformat="true"
			showtime="true"
			filter="user_utc"
		/>

		<field
			name="created_by"
			type="user"
			label="COM_MCP_FIELD_CREATED_BY_LABEL"
			validate="UserId"
		/>

		<field
			name="created_by_alias"
			type="text"
			label="COM_MCP_FIELD_CREATED_BY_ALIAS_LABEL"
		/>

		<field
			name="modified"
			type="calendar"
			label="JGLOBAL_FIELD_MODIFIED_LABEL"
			class="readonly"
			readonly="true"
			translateformat="true"
			showtime="true"
			filter="user_utc"
		/>

		<field
			name="modified_by"
			type="user"
			label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
			class="readonly"
			readonly="true"
			filter="unset"
			validate="UserId"
		/>

		<field
			name="version"
			type="text"
			label="COM_MCP_FIELD_VERSION_LABEL"
			class="readonly"
			readonly="true"
			filter="unset"
		/>

		<field
			name="publish_up"
			type="calendar"
			label="COM_MCP_FIELD_PUBLISH_UP_LABEL"
			translateformat="true"
			showtime="true"
			filter="user_utc"
		/>

		<field
			name="publish_down"
			type="calendar"
			label="COM_MCP_FIELD_PUBLISH_DOWN_LABEL"
			translateformat="true"
			showtime="true"
			filter="user_utc"
		/>
	</fieldset>
</form>
